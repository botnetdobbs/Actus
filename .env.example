DEBUG=false
APP_NAME=Actus

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# PostgreSQL: used by the actus service and constructed into DATABASE_URL by compose
POSTGRES_PASSWORD=your-postgres-password-here

# Ollama: defaults to the compose service, override if using a remote instance
OLLAMA_BASE_URL=http://ollama:11434

# Grafana admin password (login: admin / GRAFANA_PASSWORD)
GRAFANA_PASSWORD=your-grafana-password-here

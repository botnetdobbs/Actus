DEBUG=false
APP_NAME=Actus

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

POSTGRES_PASSWORD=your-postgres-password-here

# Ollama: defaults to the compose service, override if using a remote instance
OLLAMA_BASE_URL=http://ollama:11434

# Default LLM model. Agents can override per-YAML
# Local:  ollama/mistral, ollama/llama3, ollama/phi3
# Cloud:  openai/gpt-4o, anthropic/claude-sonnet-4-6 (requires API key below)
DEFAULT_MODEL=ollama/mistral

# Cloud provider API keys only needed when using non-local models
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Grafana admin password (login: admin / GRAFANA_PASSWORD)
GRAFANA_PASSWORD=your-grafana-password-here

# RAG — embedding model (pgvector runs inside PostgreSQL, no separate service needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# CORS. Restrict to your actual domains in production (default "*" raises on startup)
CORS_ORIGINS=["https://app.yourdomain.com","https://admin.yourdomain.com"]

# Set true only if the frontend needs to send cookies/auth headers cross-origin
CORS_ALLOW_CREDENTIALS=false

# JWT token lifetimes, in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# Run the in-process APScheduler. Set to false on extra replicas.
# Only one instance should run scheduled jobs to avoid duplicates.
SCHEDULER_ENABLED=true

# LLM call retry behaviour
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY=1.0

# Redis. Set automatically to the compose service by docker-compose.yml.
# Required for cross-process SSE fan-out behind a load balancer.
# Falls back to in-process DB polling if not set
REDIS_URL=redis://redis:6379

# Restrict which models callers may request via /llm/* (JSON list). Empty/unset = no restriction.
ALLOWED_MODELS=[]

# Days to retain audit log entries (incl. IP addresses) before nightly purge
AUDIT_LOG_RETENTION_DAYS=90

# CIDR(s) trusted to set X-Forwarded-For/X-Forwarded-Proto (your reverse proxy).
# Default covers the default Docker bridge network range. Narrow this to your
# proxy's actual address in production.
# FORWARDED_ALLOW_IPS=172.16.0.0/12
